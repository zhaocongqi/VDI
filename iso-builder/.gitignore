# 构建产物
dist/

# 离线资源（构建时下载，不提交到 git）
offline/images/**/*.tar
offline/images/**/*.oci
offline/binaries/*
!offline/binaries/.gitkeep
offline/packages/deb/*.deb
offline/packages/repo/
offline/charts/longhorn/*.tgz
offline/charts/kagent/*.tgz

# 临时文件
tmp/
rootfs/
iso_root/

# checksums（构建时生成）
offline/checksums.sha256

# macOS
.DS_Store

# Python 缓存
__pycache__/
*.pyc
*.pyo
