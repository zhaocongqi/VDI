# 构建缓存和产物
cache/
dist/

# live-build 工作目录
config/
chroot/
binary/
build.log

# 临时文件
*.tar
*.tar.zst
tmp/

# ========== 离线资源（构建时下载，不提交到 git）==========
# 容器镜像（OCI 目录格式，skopeo 下载）
offline/images/kubernetes/
offline/images/kube-ovn/
offline/images/kube-vip/
offline/images/kubevirt/
offline/images/longhorn/
offline/images/kagent/
offline/images/cdi/

# 二进制工具
offline/binaries/*
!offline/binaries/.gitkeep

# Helm Chart（下载的 tgz 包）
offline/charts/longhorn/*.tgz
offline/charts/kagent/*.tgz

# K8s Manifest YAML
offline/k8s-manifests/*.yaml

# 系统 deb 包
offline/packages/deb/*.deb
offline/packages/repo/

# 校验和（构建时生成）
offline/checksums.sha256

# ========== macOS ==========
.DS_Store

# ========== Python 缓存 ==========
__pycache__/
*.pyc
*.pyo

# ========== squashfs 文件 ==========
*.squashfs

# ========== ISO 文件 ==========
*.iso
