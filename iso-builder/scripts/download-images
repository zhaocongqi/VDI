#!/bin/bash
set -euo pipefail

# 下载容器镜像（OCI 目录格式）
# 使用 skopeo 从各 registry 下载，无需 Docker daemon

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WORKSPACE="$(cd "$SCRIPT_DIR/.." && pwd)"

source "${SCRIPT_DIR}/common.sh"

MANIFEST="${WORKSPACE}/offline/manifest.yaml"
IMAGES_DIR="${WORKSPACE}/offline/images"

require_cmds skopeo yq

step "下载容器镜像"

# 从 manifest.yaml 读取所有组件的镜像列表
COMPONENTS=$(yq '.components | keys | .[]' "$MANIFEST")

total_images=0
downloaded=0
failed=0

for comp in $COMPONENTS; do
    images=$(yq ".components.${comp}.images[]" "$MANIFEST" 2>/dev/null || true)
    [ -z "$images" ] && continue

    comp_dir="${IMAGES_DIR}/${comp}"
    mkdir -p "$comp_dir"

    echo ""
    step "组件 ${comp}: $(echo "$images" | wc -l) 个镜像"

    for image in $images; do
        total_images=$((total_images + 1))

        # 生成安全文件名：将 / : 替换为 _
        safe_name=$(echo "$image" | sed 's|[/:]|_|g')
        dest="${comp_dir}/${safe_name}"

        # OCI 格式使用 index.json，tar 格式使用 manifest.json
        if [ -f "${dest}/index.json" ] || [ -f "${dest}/manifest.json" ] || [ -f "${dest}.tar" ]; then
            info "已存在: ${image}"
            downloaded=$((downloaded + 1))
            continue
        fi

        echo -e "  ${YELLOW}[下载]${NC} ${image}"
        if skopeo copy --override-os linux --override-arch amd64 \
            "docker://${image}" "oci:${dest}" 2>&1; then
            downloaded=$((downloaded + 1))
        else
            error "下载失败: ${image}"
            failed=$((failed + 1))
            # 清理失败产物
            rm -rf "$dest"
        fi
    done
done

echo ""
echo "镜像下载统计:"
echo "  总计: ${total_images}"
echo "  成功: ${downloaded}"
echo "  失败: ${failed}"

if [ "$failed" -gt 0 ]; then
    error "有 ${failed} 个镜像下载失败，请检查网络后重试"
    exit 1
fi

ok "全部 ${total_images} 个镜像下载完成"
