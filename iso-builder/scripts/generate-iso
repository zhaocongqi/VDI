#!/bin/bash
set -euo pipefail

# 生成可启动 ISO 镜像
# 支持 BIOS (isolinux) + UEFI (GRUB) 双模式启动

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WORKSPACE="$(cd "$SCRIPT_DIR/.." && pwd)"
ISO_ROOT="${WORKSPACE}/iso_root"
DIST_DIR="${WORKSPACE}/dist"
VERSION="${1:-v1.0.0}"
ISO_NAME="vdi-offline-${VERSION}"

source "${SCRIPT_DIR}/common.sh"

require_cmds xorriso mksquashfs

step "准备 ISO 目录结构"
mkdir -p "${ISO_ROOT}"/{boot/grub,efi/boot,isolinux,casper,offline,scripts,configs,metadata,.disk}

# 步骤 1：复制内核和 initrd
step "复制内核和 initrd"
ROOTFS="${WORKSPACE}/rootfs"

KERNEL=$(ls "${ROOTFS}"/boot/vmlinuz-* 2>/dev/null | head -1)
INITRD=$(ls "${ROOTFS}"/boot/initrd.img-* 2>/dev/null | head -1)

if [ -n "$KERNEL" ] && [ -n "$INITRD" ]; then
    cp "$KERNEL" "${ISO_ROOT}/casper/vmlinuz"
    cp "$INITRD" "${ISO_ROOT}/casper/initrd"
    ok "内核和 initrd 已复制"
else
    error "未找到内核文件，请先执行 create-live"
    exit 1
fi

# 步骤 2：生成 isolinux 配置（BIOS 启动）
step "配置 isolinux (BIOS 启动)"
ISOLINUX_DIR="${ISO_ROOT}/isolinux"

# 复制 isolinux 引导文件
if [ -d /usr/lib/ISOLINUX ]; then
    cp /usr/lib/ISOLINUX/isolinux.bin "${ISOLINUX_DIR}/"
    cp /usr/lib/syslinux/modules/bios/ldlinux.c32 "${ISOLINUX_DIR}/" 2>/dev/null || true
    cp /usr/lib/syslinux/modules/bios/libcom32.c32 "${ISOLINUX_DIR}/" 2>/dev/null || true
    cp /usr/lib/syslinux/modules/bios/libutil.c32 "${ISOLINUX_DIR}/" 2>/dev/null || true
    # isohybrid MBR
    cp /usr/lib/ISOLINUX/isohdpfx.bin "${DIST_DIR}/" 2>/dev/null || \
        cp /usr/lib/syslinux/mbr/isohdpfx.bin "${DIST_DIR}/" 2>/dev/null || true
elif [ -d /usr/lib/syslinux ]; then
    cp /usr/lib/syslinux/isolinux.bin "${ISOLINUX_DIR}/"
    cp /usr/lib/syslinux/ldlinux.c32 "${ISOLINUX_DIR}/" 2>/dev/null || true
fi

cat > "${ISOLINUX_DIR}/isolinux.cfg" <<EOF
DEFAULT install
PROMPT 0
TIMEOUT 30

LABEL install
    MENU LABEL ^安装 VDI 集群
    KERNEL /casper/vmlinuz
    APPEND initrd=/casper/initrd boot=casper quiet splash ---

LABEL shell
    MENU LABEL ^进入 Live Shell
    KERNEL /casper/vmlinuz
    APPEND initrd=/casper/initrd boot=casper text ---
EOF

# 步骤 3：生成 GRUB 配置（UEFI 启动）
step "配置 GRUB (UEFI 启动)"
GRUB_DIR="${ISO_ROOT}/boot/grub"

cat > "${GRUB_DIR}/grub.cfg" <<'GRUBEOF'
set default=0
set timeout=30
set color_normal=white/black
set color_highlight=black/light-gray

menuentry "安装 VDI 集群" {
    linux /casper/vmlinuz boot=casper quiet splash ---
    initrd /casper/initrd
}

menuentry "进入 Live Shell" {
    linux /casper/vmlinuz boot=casper text ---
    initrd /casper/initrd
}

menuentry "安装 VDI 集群（安全模式）" {
    linux /casper/vmlinuz boot=casper nomodeset text ---
    initrd /casper/initrd
}
GRUBEOF

# 步骤 4：创建 EFI 分区镜像
step "创建 EFI 分区"
EFI_DIR="${WORKSPACE}/tmp/efi"
mkdir -p "${EFI_DIR}/EFI/BOOT"

# 使用 grub-mkimage 创建 standalone EFI 引导
if command -v grub-mkimage &>/dev/null; then
    grub-mkimage -O x86_64-efi \
        -o "${EFI_DIR}/EFI/BOOT/BOOTX64.EFI" \
        -p "/boot/grub" \
        -d /usr/lib/grub/x86_64-efi \
        linux normal iso9660 biosdisk part_msdos part_gpt fat \
        search search_fs_file search_fs_uuid search_label \
        gfxterm gfxterm_background gfxterm_menu halt reboot \
        configfile echo ls cat chain loadenv
    ok "GRUB EFI 引导已创建"
else
    info "grub-mkimage 不可用，尝试直接复制"
    if [ -f /usr/lib/grub/x86_64-efi/grubx64.efi ]; then
        cp /usr/lib/grub/x86_64-efi/grubx64.efi "${EFI_DIR}/EFI/BOOT/BOOTX64.EFI"
    fi
fi

# 创建 EFI FAT 镜像
dd if=/dev/zero of="${ISO_ROOT}/efi/boot/efiboot.img" bs=1M count=8 2>/dev/null
mkfs.vfat -F 12 "${ISO_ROOT}/efi/boot/efiboot.img"
mmd -i "${ISO_ROOT}/efi/boot/efiboot.img" ::EFI ::EFI/BOOT
mcopy -i "${ISO_ROOT}/efi/boot/efiboot.img" \
    "${EFI_DIR}/EFI/BOOT/BOOTX64.EFI" "::EFI/BOOT/BOOTX64.EFI"
rm -rf "${WORKSPACE}/tmp/efi"

# 步骤 5：创建 .disk/info（ISO 元数据）
step "写入 ISO 元数据"
echo "VDI Offline Install ${VERSION} - amd64 ($(date '+%Y-%m-%d %H:%M:%S'))" > "${ISO_ROOT}/.disk/info"
echo "${ISO_NAME}" > "${ISO_ROOT}/.disk/base_installable"

# 步骤 6：查找 isohdpfx.bin 用于 isohybrid
ISOHYBRID_MBR=""
for path in \
    /usr/lib/ISOLINUX/isohdpfx.bin \
    /usr/lib/syslinux/mbr/isohdpfx.bin \
    /usr/lib/syslinux/isohdpfx.bin; do
    if [ -f "$path" ]; then
        ISOHYBRID_MBR="$path"
        break
    fi
done

# 步骤 7：使用 xorriso 打包
step "生成 ISO 镜像"
mkdir -p "${DIST_DIR}"

XORRISO_ARGS=(
    -as mkisofs
    -o "${DIST_DIR}/${ISO_NAME}.iso"
    -V "VDI-INSTALL"
    -R -J
    # BIOS 启动
    -b isolinux/isolinux.bin
    -c isolinux/boot.cat
    -no-emul-boot
    -boot-load-size 4
    -boot-info-table
    # UEFI 启动
    -eltorito-alt-boot
    -e efi/boot/efiboot.img
    -no-emul-boot
)

# 添加 isohybrid 支持（如果找到 MBR 文件）
if [ -n "$ISOHYBRID_MBR" ]; then
    XORRISO_ARGS+=(
        -isohybrid-mbr "$ISOHYBRID_MBR"
        -isohybrid-gpt-basdat
    )
fi

XORRISO_ARGS+=("${ISO_ROOT}")

xorriso "${XORRISO_ARGS[@]}"

ok "ISO 镜像已生成: ${DIST_DIR}/${ISO_NAME}.iso"
info "ISO 大小: $(du -sh "${DIST_DIR}/${ISO_NAME}.iso" | cut -f1)"
