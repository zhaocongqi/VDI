#!/bin/bash
set -euo pipefail

# 将 TUI 安装器集成到 ISO 和 Live 系统

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WORKSPACE="$(cd "$SCRIPT_DIR/.." && pwd)"
ISO_ROOT="${WORKSPACE}/iso_root"
ROOTFS="${WORKSPACE}/rootfs"

source "${SCRIPT_DIR}/common.sh"

step "集成 TUI 安装器"

# 步骤 1：复制 TUI 到 Live 系统
if [ -d "${WORKSPACE}/tui" ]; then
    mkdir -p "${ROOTFS}/opt/vdi/tui"
    rsync -a "${WORKSPACE}/tui/" "${ROOTFS}/opt/vdi/tui/"
    # 确保主程序可执行
    [ -f "${ROOTFS}/opt/vdi/tui/installer.py" ] && \
        chmod +x "${ROOTFS}/opt/vdi/tui/installer.py"
    ok "TUI 已复制到 Live 系统 /opt/vdi/tui/"
else
    info "tui/ 目录不存在，跳过 TUI 集成"
fi

# 步骤 2：复制 TUI 到 ISO（备选路径）
if [ -d "${WORKSPACE}/tui" ]; then
    rsync -a "${WORKSPACE}/tui/" "${ISO_ROOT}/tui/"
    ok "TUI 已复制到 ISO"
fi

ok "TUI 集成完成"
