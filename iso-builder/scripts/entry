#!/bin/bash
set -euo pipefail

# Dapper 入口脚本
# 透传命令行参数给主构建脚本

# 如果没有参数，显示帮助
if [ $# -eq 0 ]; then
    echo "VDI 离线 ISO 构建系统"
    echo ""
    echo "用法: ./scripts/entry <命令> [参数]"
    echo ""
    echo "命令:"
    echo "  build [版本号]    完整构建 ISO"
    echo "  download         下载离线资源"
    echo "  shell            进入交互 shell"
    echo ""
    exit 0
fi

exec "$@"
