#!/bin/bash
set -euo pipefail

# 将离线资源集成到 ISO 目录结构
# 复制 deploy/ 目录和离线资源包到 ISO

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WORKSPACE="$(cd "$SCRIPT_DIR/.." && pwd)"
ISO_ROOT="${WORKSPACE}/iso_root"
VDI_ROOT="$(cd "${WORKSPACE}/.." && pwd)"

source "${SCRIPT_DIR}/common.sh"

step "集成离线资源到 ISO"

# 步骤 1：复制离线资源
step "复制离线资源包"
if [ -d "${WORKSPACE}/offline" ]; then
    rsync -a --exclude='.gitkeep' \
        "${WORKSPACE}/offline/" "${ISO_ROOT}/offline/"
    ok "离线资源已复制"
else
    info "离线资源目录不存在，跳过"
fi

# 步骤 2：复制 VDI deploy 目录
step "复制 VDI 部署脚本"
VDI_DEPLOY="${VDI_ROOT}/deploy"
if [ -d "$VDI_DEPLOY" ]; then
    # 排除敏感文件和 gitignore 文件
    rsync -a \
        --exclude='hosts' \
        --exclude='k8s/inventory.yaml' \
        --exclude='.git' \
        "${VDI_DEPLOY}/" "${ISO_ROOT}/scripts/deploy/"
    ok "部署脚本已复制"
else
    info "deploy/ 目录不存在，跳过"
fi

# 步骤 3：复制配置文件模板
step "复制配置文件模板"
if [ -d "${WORKSPACE}/configs" ]; then
    rsync -a "${WORKSPACE}/configs/" "${ISO_ROOT}/configs/"
    ok "配置文件已复制"
fi

# 步骤 4：复制离线资源加载脚本
step "复制离线加载脚本"
mkdir -p "${ISO_ROOT}/scripts"
for script in load-offline-images setup-local-repo verify-offline-pack; do
    if [ -f "${WORKSPACE}/scripts/${script}" ]; then
        cp "${WORKSPACE}/scripts/${script}" "${ISO_ROOT}/scripts/"
    fi
done

# 步骤 5：生成离线环境变量配置
step "配置离线环境变量"
mkdir -p "${ISO_ROOT}/configs"
cat > "${ISO_ROOT}/configs/env-offline.sh" <<'ENVEOF'
#!/bin/bash
# 离线环境变量（ISO 挂载后自动设置）
# 此文件由构建系统自动生成

# 检测 ISO 挂载点
if [ -d /cdrom/offline ]; then
    export OFFLINE_BASE="/cdrom/offline"
elif [ -d /mnt/iso/offline ]; then
    export OFFLINE_BASE="/mnt/iso/offline"
else
    unset OFFLINE_BASE
fi

if [ -n "${OFFLINE_BASE:-}" ]; then
    export OFFLINE_BINARIES="${OFFLINE_BASE}/binaries"
    export OFFLINE_IMAGES="${OFFLINE_BASE}/images"
    export OFFLINE_CHARTS="${OFFLINE_BASE}/charts"
    export OFFLINE_MANIFESTS="${OFFLINE_BASE}/k8s-manifests"
    export OFFLINE_PACKAGES="${OFFLINE_BASE}/packages/deb"

    # 将离线工具加入 PATH
    export PATH="${OFFLINE_BINARIES}:${PATH}"

    echo "[离线模式] 资源路径: ${OFFLINE_BASE}"
fi
ENVEOF
ok "离线环境变量配置已生成"

# 步骤 6：安装到 Live 系统
if [ -d "${WORKSPACE}/rootfs" ]; then
    cp "${ISO_ROOT}/configs/env-offline.sh" "${WORKSPACE}/rootfs/etc/profile.d/vdi-offline.sh"
    chmod +x "${WORKSPACE}/rootfs/etc/profile.d/vdi-offline.sh"
    ok "离线变量已安装到 Live 系统"
fi

ok "离线资源集成完成"
