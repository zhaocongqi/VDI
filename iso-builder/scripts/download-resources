#!/bin/bash
set -euo pipefail

# 离线资源总下载入口
# 按顺序下载所有类型的离线资源

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WORKSPACE="$(cd "$SCRIPT_DIR/.." && pwd)"

source "${SCRIPT_DIR}/common.sh"

MANIFEST="${WORKSPACE}/offline/manifest.yaml"

if [ ! -f "$MANIFEST" ]; then
    error "manifest.yaml 不存在: $MANIFEST"
    exit 1
fi

echo "============================================"
echo "  VDI 离线资源下载"
echo "  清单: $MANIFEST"
echo "============================================"

# 按顺序执行各下载脚本
for script in download-images download-binaries download-packages download-charts download-manifests; do
    if [ -f "${SCRIPT_DIR}/${script}" ]; then
        echo ""
        step "执行 ${script}"
        "${SCRIPT_DIR}/${script}"
    else
        info "脚本不存在: ${SCRIPT_DIR}/${script}，跳过"
    fi
done

# 生成校验和
step "生成校验和文件"
cd "${WORKSPACE}"
find offline/ -type f \
    ! -name 'checksums.sha256' \
    ! -name '.gitkeep' \
    ! -name 'manifest.yaml' \
    -exec sha256sum {} \; > offline/checksums.sha256
ok "校验和文件已生成: offline/checksums.sha256"

# 统计下载资源
TOTAL_SIZE=$(du -sh "${WORKSPACE}/offline" | cut -f1)
FILE_COUNT=$(find "${WORKSPACE}/offline" -type f ! -name '.gitkeep' ! -name 'checksums.sha256' ! -name 'manifest.yaml' | wc -l)
echo ""
echo "============================================"
ok "资源下载完成"
echo "  总大小: ${TOTAL_SIZE}"
echo "  文件数: ${FILE_COUNT}"
echo "============================================"
