#!/bin/bash
set -euo pipefail

# VDI 离线 ISO 主构建脚本
# 编排完整构建流程：下载资源 → 创建 Live 系统 → 集成离线资源 → 打包 ISO

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WORKSPACE="$(cd "$SCRIPT_DIR/.." && pwd)"
VERSION="${1:-v1.0.0}"
ISO_NAME="vdi-offline-${VERSION}"
DIST_DIR="${WORKSPACE}/dist"

source "${SCRIPT_DIR}/common.sh"

echo "============================================"
echo "  VDI 离线 ISO 构建"
echo "  版本: ${VERSION}"
echo "  时间: $(date '+%Y-%m-%d %H:%M:%S')"
echo "============================================"

# 步骤 1：准备输出目录
step "准备输出目录"
mkdir -p "${DIST_DIR}"

# 步骤 2：下载离线资源（如果尚未下载）
step "检查离线资源"
if [ ! -f "${WORKSPACE}/offline/checksums.sha256" ]; then
    step "下载离线资源"
    "${SCRIPT_DIR}/download-resources"
else
    info "离线资源已存在，跳过下载"
fi

# 步骤 3：校验离线资源
step "校验离线资源完整性"
if ! sha256sum -c "${WORKSPACE}/offline/checksums.sha256" --quiet 2>/dev/null; then
    error "离线资源校验失败，请执行 make distclean && make download 重新下载"
    exit 1
fi
ok "离线资源校验通过"

# 步骤 4：创建 Live 系统根文件系统
step "创建 Live 系统根文件系统"
"${SCRIPT_DIR}/create-live"

# 步骤 5：集成离线资源到 ISO
step "集成离线资源到 ISO"
"${SCRIPT_DIR}/integrate-offline"

# 步骤 6：集成 TUI 安装器
step "集成 TUI 安装器"
"${SCRIPT_DIR}/integrate-tui"

# 步骤 7：生成 ISO 镜像
step "生成 ISO 镜像"
"${SCRIPT_DIR}/generate-iso" "${VERSION}"

# 步骤 8：生成校验和
step "生成校验和文件"
sha256sum "${DIST_DIR}/${ISO_NAME}.iso" > "${DIST_DIR}/${ISO_NAME}.iso.sha256"

# 步骤 9：生成 manifest
step "生成构建 manifest"
"${SCRIPT_DIR}/generate-manifest" "${VERSION}" > "${DIST_DIR}/${ISO_NAME}.manifest"

echo ""
echo "============================================"
ok "构建完成!"
echo "  ISO: ${DIST_DIR}/${ISO_NAME}.iso"
echo "  大小: $(du -sh "${DIST_DIR}/${ISO_NAME}.iso" | cut -f1)"
echo "  SHA256: ${DIST_DIR}/${ISO_NAME}.iso.sha256"
echo "============================================"
