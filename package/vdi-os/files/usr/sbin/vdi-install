#!/bin/bash -e
# VDI OS 安装脚本
# 对应 Harvester 的 harv-install，适配 RKE2 + VDI 组件
# 去除 Rancherd 相关逻辑，直接使用 RKE2 镜像预加载

ISOMNT=/run/initramfs/live
TARGET=/run/cos/target
DATA_DISK_FSLABEL="VDI_LH_DEFAULT"
declare -a CLEAR_FSLABELS=(
  "$DATA_DISK_FSLABEL"
  "COS_OEM"
  "COS_STATE"
  "COS_PERSISTENT"
  "COS_RECOVERY"
)

clear_disk_label()
{
    echo "Assessing labels on data disk $VDI_DATA_DISK partitions."
    for part in $(lsblk $VDI_DATA_DISK -npr -oname,type | grep part | cut -d' ' -f1); do
        partition_label=$(blkid -s LABEL -o value $part)
        for label in "${CLEAR_FSLABELS[@]}"; do
            if [ "$partition_label" == "$label" ] ; then
                echo "Removing filesystem label $label from $part"
                tune2fs -L "" $part > /dev/null || tune2fs -L "" $part > /dev/null
            fi
        done
    done
    udevadm settle
}

umount_target() {
    sync
    umount ${TARGET}/oem
    umount ${TARGET}/usr/local
    umount ${TARGET}/boot/efi || true
    umount ${TARGET}
    if [ -n "$LOOP" ]; then
        losetup -d $LOOP
    fi
}

cleanup2()
{
    sync
    [ -n "$VDI_ISO_URL" ] && umount "$ISOMNT" || true
    umount_target || true
    umount ${STATEDIR}
}

cleanup()
{
    EXIT=$?
    cleanup2 2>/dev/null || true
    return $EXIT
}

do_detect()
{
    echo "Detecting drives.."
    OEM=$(blkid -L COS_OEM || true)
    STATE=$(blkid -L COS_STATE || true)
    PERSISTENT=$(blkid -L COS_PERSISTENT || true)
}

do_mount()
{
    echo "Mounting critical endpoints.."
    mkdir -p ${TARGET}
    STATEDIR=/tmp/mnt/STATE
    mkdir -p $STATEDIR || true
    mount ${STATE} $STATEDIR
    LOOP=$(losetup --show -f ${STATEDIR}/cOS/active.img)
    mount -t ext2 $LOOP $TARGET
    mkdir -p ${TARGET}/oem
    mount ${OEM} ${TARGET}/oem
    mkdir -p ${TARGET}/usr/local
    mount ${PERSISTENT} ${TARGET}/usr/local
}

do_data_disk_format()
{
    if [ -z $VDI_DATA_DISK ]; then
        return
    fi

    local data_disk_device=$VDI_DATA_DISK
    if [ -L "$VDI_DATA_DISK" ]; then
      data_disk_device=$(readlink -f "$VDI_DATA_DISK")
    fi

    echo "Formatting $VDI_DATA_DISK as data disk..."
    mkfs.ext4 -F -L "$DATA_DISK_FSLABEL" "$VDI_DATA_DISK"
}

preload_rke2_images()
{
    preload=$(ls ${ISOMNT}/bundle/vdi/images/*.tar.zst 2>/dev/null || true)
    if [ -z "$preload" ]; then
        return
    fi

    if [ -n "$VDI_ISO_URL" ]; then
        INSTALL_MODE="PXE"
    else
        INSTALL_MODE="ISO"
    fi

    readonly RKE2_IMAGES_DIR="/var/lib/rancher/rke2/agent/images"
    readonly TMP_IMAGES_DIR="/usr/local/rancher/tmp/images"
    readonly IMAGES_LISTS_DIR="/tmp/images-lists"
    readonly AGENT_IMAGES_DIR="/var/lib/rancher/agent/images"
    mkdir -p $TARGET/$RKE2_IMAGES_DIR
    mkdir -p $TARGET/$TMP_IMAGES_DIR
    mkdir -p $TARGET/$IMAGES_LISTS_DIR
    mkdir -p $TARGET/$AGENT_IMAGES_DIR

    if [ "$INSTALL_MODE" = "ISO" ]; then
        echo "Copying RKE2 images to the target location..."
        rsync -ahv --progress ${ISOMNT}/bundle/vdi/images/rke2-images.*.tar.zst $TARGET/$RKE2_IMAGES_DIR
        echo "Copying remaining images to temporary location..."
        rsync -ahv --progress ${ISOMNT}/bundle/vdi/images/ $TARGET/$TMP_IMAGES_DIR
        rsync -ahv --progress ${ISOMNT}/bundle/vdi/images-lists/ $TARGET/$IMAGES_LISTS_DIR
        # rancherd bootstrap images（system-agent-installer-rke2 镜像 tar + 列表，chroot 用 wharfie 提取 rke2 二进制+containerd）
        cp ${ISOMNT}/bundle/rancherd/images/* $TARGET/$AGENT_IMAGES_DIR/
    else
        echo "Bind-mount images directory to the target location..."
        mount --bind ${ISOMNT}/bundle/vdi/images $TARGET/$RKE2_IMAGES_DIR
        mount --bind ${ISOMNT}/bundle/vdi/images-lists $TARGET/$IMAGES_LISTS_DIR
        cp ${ISOMNT}/bundle/rancherd/images/* $TARGET/$AGENT_IMAGES_DIR/
    fi

    cd $TARGET
    mount --bind /dev dev
    mount --bind /proc proc
    mount --rbind /sys sys

    echo "Loading images. This may take a few minutes..."
    install_mode="$INSTALL_MODE" tmp_images_dir="$TMP_IMAGES_DIR" images_lists_dir="$IMAGES_LISTS_DIR" chroot . /bin/bash <<"EOF"
      set -e

      wait_for_containerd_ready()
      {
        until ctr --connect-timeout 1s version&>/dev/null
        do
            sleep 1
        done
      }

      inst_tmp=$(mktemp -d -p /usr/local)
      trap "rm -rf $inst_tmp" exit

      # 从 rancherd-bootstrap-images 列表找 system-agent-installer-rke2 镜像（wharfie 提取 rke2 二进制+containerd）
      image_list=$(ls /var/lib/rancher/agent/images/rancherd-bootstrap-images-*.txt 2>/dev/null | head -n 1)
      if [ -z "$image_list" ]; then
        echo "[ERROR] Fail to get rancherd bootstrap images list."
        exit 1
      fi

      # Start temporary RKE2 to load images
      rke2_image=$(grep 'docker.io/rancher/system-agent-installer-rke2:' $image_list || true)
      if [ -n "$rke2_image" ]; then
        wharfie --images-dir /var/lib/rancher/agent/images/ $rke2_image $inst_tmp
        rke2_tmp="$inst_tmp/rke2"
        if [ ${HOSTTYPE} = "aarch64" ]; then
          mkdir -p $rke2_tmp && tar xf $inst_tmp/rke2.linux-arm64.tar.gz -C $rke2_tmp
        else
          mkdir -p $rke2_tmp && tar xf $inst_tmp/rke2.linux-amd64.tar.gz -C $rke2_tmp
        fi
        $rke2_tmp/bin/rke2 server &> /rke2.log &
        export PATH=/var/lib/rancher/rke2/bin:$PATH
        export CONTAINERD_ADDRESS=/run/k3s/containerd/containerd.sock
        wait_for_containerd_ready
      fi

      if [ "$install_mode" = "ISO" ]; then
        echo "Stop RKE2 and remove temporary RKE2 files..."
        pkill rke2 || true
        rm -f /rke2.log
        rm -f /etc/rancher/rke2/rke2.yaml
        rm -rf /var/lib/rancher/rke2/server
        rm -rf /var/lib/rancher/rke2/agent/pod-manifests/*

        echo "Start containerd..."
        containerd -c /var/lib/rancher/rke2/agent/etc/containerd/config.toml -a $CONTAINERD_ADDRESS --state /run/k3s/containerd --root /var/lib/rancher/rke2/agent/containerd &> /containerd.log &
        wait_for_containerd_ready

        # load images
        for i in $tmp_images_dir/*.tar.zst; do
            echo "Load images from $i"
            zstd -d $i -o /usr/local/images.tar
            ctr -n k8s.io images import --no-unpack /usr/local/images.tar
            rm /usr/local/images.tar
            rm -f $i
        done
      fi

      # verify images
      for i in $images_lists_dir/*.txt; do
        echo "Verifying images in $i"
        while IFS= read -r img; do
          [ -z "$img" ] && continue
          ctr -n k8s.io images ls -q | grep -q "$img" || echo "WARNING: missing $img"
        done < "$i"
      done

      # teardown
      if [ "$install_mode" = "ISO" ]; then
        echo "Stop containerd..."
        pkill containerd || true
        rm -f /containerd.log
      else
        echo "Stop RKE2..."
        pkill rke2 || true
        rm -f /rke2.log
        rm -f /etc/rancher/rke2/rke2.yaml
        rm -rf /var/lib/rancher/rke2/server
        rm -rf /var/lib/rancher/rke2/agent/pod-manifests/*
      fi
EOF

    until umount dev&>/dev/null
    do
        sleep 1
    done
    umount proc
    cd - &> /dev/null
    if [ "$INSTALL_MODE" = "ISO" ]; then
        rm -rf ${TARGET}/${RKE2_IMAGES_DIR}/*
        rm -rf ${TARGET}/${TMP_IMAGES_DIR}
        rm -rf ${TARGET}/${IMAGES_LISTS_DIR}/*
    else
        umount ${TARGET}/${RKE2_IMAGES_DIR}
        umount ${TARGET}/${IMAGES_LISTS_DIR}
    fi
}

save_configs()
{
    save_dir=${TARGET}/oem
    if [ -e "$VDI_CONFIG" ]; then
        cp $VDI_CONFIG $save_dir/vdi.config
    fi
    if [ -e "$ELEMENTAL_CONFIG" ]; then
        cp $ELEMENTAL_CONFIG $save_dir/elemental.config
    fi
}

save_nm_state()
{
    if [ "$VDI_MODE" = "install" ]; then
        echo "installer running in install mode only, no network manager persistence required"
        return
    fi
    local nm_state="${TARGET}/usr/local/.state/var-lib-NetworkManager.bind"
    mkdir -p ${nm_state}
    cp -r /var/lib/NetworkManager/. ${nm_state}
    local nm_conn="${TARGET}/usr/local/.state/etc-NetworkManager.bind/system-connections"
    mkdir -p ${nm_conn}
    cp -a /etc/NetworkManager/system-connections/* ${nm_conn}
}

update_grub_settings()
{
    if [ -z "${VDI_TTY}" ]; then
        TTY=$(tty | sed 's!/dev/!!')
    else
        TTY=$VDI_TTY
    fi
    if [ -e "/dev/${TTY%,*}" ] && [ "$TTY" != tty1 ] && [ "$TTY" != console ] && [ -n "$TTY" ]; then
        sed -i "s/console_params=\"console=tty1\"/console_params=\"console=${TTY} console=tty1\"/g" ${TARGET}/etc/cos/bootargs.cfg
    fi
}

save_installation_log()
{
    save_dir=${TARGET}/oem/install
    mkdir -p $save_dir
    if [ -e "$VDI_INSTALLATION_LOG" ]; then
        fsync $VDI_INSTALLATION_LOG
        cp $VDI_INSTALLATION_LOG $save_dir
    fi
}

trap cleanup exit

# 抑制 LVM 文件描述符警告（安装器未设置 FD_CLOEXEC 导致）
export LVM_SUPPRESS_FD_WARNINGS=1

# 创建临时 LVM 配置，去除 global_filter 以确保 blkdeactivate 能正常工作
export LVM_SYSTEM_DIR=$(mktemp -d)
lvmconfig | sed /global_filter/d > ${LVM_SYSTEM_DIR}/lvm.conf

# 拆除系统上的 LVM 和 MD 设备，避免后续分区操作失败
blkdeactivate --lvmoptions wholevg,retry --dmoptions force,retry --errors || true

clear_disk_label

# 运行 elemental 安装器（不获取 ISO，不关机）
elemental install --config-dir ${ELEMENTAL_CONFIG_DIR} --debug

# 格式化数据盘（如需要）
do_data_disk_format

do_detect
do_mount

save_configs
save_nm_state

# Bind mount var/lib/rancher 到 PERSISTENT（usr/local），containerd 镜像数据写 PERSISTENT 不占 active.img（对齐 harvester do_preload）
RANCHER_BIND_MOUNTS=("var/lib/rancher")
for i in ${RANCHER_BIND_MOUNTS[@]}; do
    state_dir="/usr/local/.state/${i//\//-}.bind"
    mkdir -p $TARGET/$i
    mkdir -p $TARGET/$state_dir
    mount -o bind $TARGET/$state_dir $TARGET/$i
done

preload_rke2_images

for i in ${RANCHER_BIND_MOUNTS[@]}; do
    umount $TARGET/$i
done

update_grub_settings

# 日志必须最后保存，因为它会捕获本脚本的输出
save_installation_log
