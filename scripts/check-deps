#!/bin/bash
# 构建前置检查：确认外部依赖就绪，缺失时明确报错指引
# 用法: make check-deps（也被 scripts/default 自动调用）

TOP_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." &> /dev/null && pwd )"
ERR=0

# BCLinux ISO（客户提供，无法自动下载）
ISO="${TOP_DIR}/dist/iso/BCLinux-21.10U5-dvd-x86_64-260610.iso"
if [ ! -s "${ISO}" ]; then
    echo "ERROR: 缺少 BCLinux ISO: ${ISO}" >&2
    echo "       客户提供，放至 dist/iso/" >&2
    ERR=1
fi

# elemental / wharfie / yip（可 make fetch-deps 下载）
for bin in elemental wharfie yip; do
    if [ ! -s "${TOP_DIR}/package/vdi-os/files/usr/bin/${bin}" ]; then
        echo "ERROR: 缺少 ${bin} 二进制: package/vdi-os/files/usr/bin/${bin}" >&2
        echo "       运行 make fetch-deps 下载" >&2
        ERR=1
    fi
done

if [ ${ERR} -ne 0 ]; then
    echo ">>> 依赖检查未通过（上方 ERROR），请补齐后重试" >&2
    exit 1
fi
echo ">>> 依赖检查通过"
