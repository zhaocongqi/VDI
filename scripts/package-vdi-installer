#!/bin/bash -e

TOP_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." &> /dev/null && pwd )"
SCRIPTS_DIR="${TOP_DIR}/scripts"
DIST_INSTALLER_DIR="${TOP_DIR}/dist/vdi-installer"
PACKAGE_VDI_INSTALLER_DIR="${TOP_DIR}/package/vdi-installer"

source ${SCRIPTS_DIR}/version

# for image publish in CI
rm -rf ${DIST_INSTALLER_DIR} && mkdir -p ${DIST_INSTALLER_DIR}
cp -r ${PACKAGE_VDI_INSTALLER_DIR}/* ${DIST_INSTALLER_DIR}

cd ${PACKAGE_VDI_INSTALLER_DIR}

INSTALLER_IMAGE=rancher/vdi-installer:${VERSION}
docker build -t ${INSTALLER_IMAGE} .
