#!/bin/bash -e
# 构建 VDI Live ISO（使用 elemental build-iso）
# 参考 Harvester 的 scripts/package-harvester-os
#
# 流程：
#   0. 生成 vdi-release.yaml
#   1. 确保 BCLinux 基础镜像存在
#   2. 准备本地 BCLinux 仓库（供 Dockerfile 中 dnf 使用）
#   3. docker buildx build 构建 VDI OS 镜像（含 dracut 重建的 initrd）
#   4. 提取 elemental / kernel / initrd（一次 docker create）
#   5. elemental build-iso 打包 Live ISO（squashfs + kernel + initrd + GRUB）
#   6. 字节级注入 grubx64.efi 到 EFI 引导镜像
#   7. 验证 ISO + 生成 SHA512

TOP_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." &> /dev/null && pwd )"
SCRIPTS_DIR="${TOP_DIR}/scripts"
PACKAGE_VDI_OS_DIR="${TOP_DIR}/package/vdi-os"

source ${SCRIPTS_DIR}/version-rke2
source ${SCRIPTS_DIR}/version-kubevirt
source ${SCRIPTS_DIR}/version-longhorn
source ${SCRIPTS_DIR}/version-kubeovn
source ${SCRIPTS_DIR}/version-kagent
source ${SCRIPTS_DIR}/version

# 前置检查：BCLinux ISO + elemental + wharfie
${SCRIPTS_DIR}/check-deps

VDI_OS_IMAGE=rancher/vdi-os:${VERSION}
PRETTY_NAME="VDI ${VERSION}"
CACHE_DIR="${TOP_DIR}/cache"
ARTIFACTS_DIR="${TOP_DIR}/dist/artifacts"
BCLINUX_ISO="${TOP_DIR}/dist/iso/BCLinux-21.10U5-dvd-x86_64-260610.iso"

echo "============================================"
echo "  构建 VDI Live ISO (BCLinux + elemental)"

# ============================================================
# 清理旧的构建产物
# ============================================================
echo ">>> 清理旧的构建产物"
rm -f ${ARTIFACTS_DIR}/*.iso ${ARTIFACTS_DIR}/*.sha512 ${ARTIFACTS_DIR}/*.sha256 \
      ${ARTIFACTS_DIR}/*-initrd-* ${ARTIFACTS_DIR}/*-vmlinuz-*
rm -rf ${CACHE_DIR}/iso-staging ${CACHE_DIR}/writable-rootfs \
            ${CACHE_DIR}/initrd-work ${CACHE_DIR}/efi-iso ${CACHE_DIR}/efi-boot.img 2>/dev/null || true
echo "  清理完成"
echo "  版本: ${VERSION}"
echo "  RKE2: ${RKE2_VERSION}"
echo "  KubeVirt: ${KUBEVIRT_VERSION}"
echo "  Longhorn: ${LONGHORN_VERSION}"
echo "  Kube-OVN: ${KUBEOVN_VERSION}"
echo "  kagent: ${KAGENT_VERSION}"
echo "============================================"

# ============================================================
# 步骤 0: 生成 vdi-release.yaml
# ============================================================
cat > ${PACKAGE_VDI_OS_DIR}/vdi-release.yaml <<EOF
vdi: ${VERSION}
installer: ${COMMIT}
os: ${PRETTY_NAME}
rke2: ${RKE2_VERSION}
kubevirt: ${KUBEVIRT_VERSION}
longhorn: ${LONGHORN_VERSION}
kubeovn: ${KUBEOVN_VERSION}
kagent: ${KAGENT_VERSION}
EOF

# ============================================================
# 步骤 1: 确保 BCLinux 基础镜像存在
# ============================================================
if ! docker image inspect bclinux:21.10U5 > /dev/null 2>&1; then
    echo ">>> BCLinux 基础镜像不存在，开始构建..."
    ${SCRIPTS_DIR}/build-bclinux-base
fi

# ============================================================
# 步骤 2: 准备本地 BCLinux 仓库（供 Dockerfile 中 dnf 使用）
# Dockerfile 用 RUN --mount=type=bind,from=bclinux-repo 挂载，
# 因此必须用 docker buildx build --build-context bclinux-repo=<dir>
# ============================================================
# buildx --build-context 由容器内 buildx CLI 解析，用容器内路径（REPO_DIR）
REPO_DIR="${CACHE_DIR}/bclinux-repo"
if [ ! -d "${REPO_DIR}/Packages" ] || [ ! -d "${REPO_DIR}/repodata" ]; then
    echo ">>> 准备本地 BCLinux 仓库"
    rm -rf "${REPO_DIR}"
    mkdir -p "${REPO_DIR}"
    7z x -o"${REPO_DIR}" "${BCLINUX_ISO}" Packages repodata -y 2>/dev/null
fi

# ============================================================
# 步骤 3: 构建 VDI OS Docker 镜像
# 关键：使用 buildx --build-context 挂载 BCLinux 仓库
# ============================================================
echo ">>> 构建 VDI OS 镜像: ${VDI_OS_IMAGE}"

cd ${PACKAGE_VDI_OS_DIR}
docker buildx build \
    --build-context bclinux-repo="${REPO_DIR}" \
    --build-arg BASE_OS_IMAGE="bclinux:21.10U5" \
    --build-arg VDI_PRETTY_NAME="${PRETTY_NAME}" \
    --build-arg ARCH="${ARCH}" \
    -t ${VDI_OS_IMAGE} --load .

# ============================================================
# 步骤 4: 提取 elemental / kernel / initrd（一次 docker create）
# ============================================================
# elemental build-iso 需在宿主机执行；kernel/initrd 供 PXE/调试
echo ">>> 提取 elemental / kernel / initrd"
rm -f /tmp/vdi-os-extract
docker create --cidfile=/tmp/vdi-os-extract ${VDI_OS_IMAGE} -- tail -f /dev/null
CONTAINER_ID=$(</tmp/vdi-os-extract)

# elemental 二进制（docker cp 到文件，不能用 stdout 管道会变 tar 流）
docker cp ${CONTAINER_ID}:/usr/bin/elemental /usr/bin/elemental
chmod +x /usr/bin/elemental

# BCLinux 没有 /boot/vmlinuz 软链接，用实际版本路径
KERNEL_PATH=$(docker run --rm ${VDI_OS_IMAGE} bash -c "ls /boot/vmlinuz-* 2>/dev/null | head -1")
INITRD_PATH=$(docker run --rm ${VDI_OS_IMAGE} bash -c "ls /boot/initrd-* 2>/dev/null | head -1")
if [ -z "${KERNEL_PATH}" ] || [ -z "${INITRD_PATH}" ]; then
    echo "ERROR: 找不到 kernel 或 initrd (KERNEL=${KERNEL_PATH} INITRD=${INITRD_PATH})"
    docker rm ${CONTAINER_ID} && rm -f /tmp/vdi-os-extract
    exit 1
fi
mkdir -p ${ARTIFACTS_DIR}
docker cp ${CONTAINER_ID}:${KERNEL_PATH} ${ARTIFACTS_DIR}/vdi-${VERSION}-vmlinuz-${ARCH}
docker cp ${CONTAINER_ID}:${INITRD_PATH} ${ARTIFACTS_DIR}/vdi-${VERSION}-initrd-${ARCH}
chmod +r ${ARTIFACTS_DIR}/vdi-${VERSION}-initrd-${ARCH}

docker rm ${CONTAINER_ID} && rm -f /tmp/vdi-os-extract
echo "  elemental: $(elemental --version 2>/dev/null || echo unknown)"
echo "  kernel: $(ls -lh ${ARTIFACTS_DIR}/vdi-${VERSION}-vmlinuz-${ARCH} | awk '{print $5}')"
echo "  initrd: $(ls -lh ${ARTIFACTS_DIR}/vdi-${VERSION}-initrd-${ARCH} | awk '{print $5}')"

# ============================================================
# 步骤 6: 用 elemental build-iso 构建 Live ISO
# elemental 自动从 Docker 镜像提取 rootfs 并打包 squashfs + kernel + initrd + GRUB
# ============================================================
echo ">>> 构建 Live ISO (elemental build-iso)"
ISO_PREFIX="vdi-${VERSION}-${ARCH}"

cd ${PACKAGE_VDI_OS_DIR}
# DOCKER_API_VERSION: elemental 内嵌的 Docker client 是 1.42，daemon 要求 1.44
# --platform 用 linux/${ARCH}（GOARCH 格式，elemental 默认即 linux/amd64）
DOCKER_API_VERSION=1.44 DOCKER_HOST=unix:///var/run/docker.sock elemental build-iso \
    --config-dir "${PACKAGE_VDI_OS_DIR}" \
    --debug \
    "docker:${VDI_OS_IMAGE}" \
    --local \
    -n "${ISO_PREFIX}" \
    -o "${ARTIFACTS_DIR}" \
    --overlay-iso "${PACKAGE_VDI_OS_DIR}/iso" \
    -x "-comp xz" \
    --platform "linux/${ARCH}"

cd ${TOP_DIR}

# ============================================================
# 步骤 7: 字节级注入 grubx64.efi 到 EFI 引导镜像
# ============================================================
# elemental build-iso 默认只把 grub.efi 放进 EFI 引导镜像，但 BCLinux shim
# 硬编码找 grubx64.efi，缺失会导致 UEFI 引导失败。
#
# 此前用 xorriso 全量重建 ISO 注入，但 3.3GB ISO 重建后体积超 xorriso stdio
# 媒体容量上限（~3174MB）导致重建失败。改为字节级注入：直接定位 ISO 中 EFI
# 引导镜像（8MB FAT，卷标 COS_GRUB）的偏移，用 mtools 注入 grubx64.efi 后
# 用 dd 原位写回，不重建 ISO，绕过容量限制。
ISO_FILE="${ARTIFACTS_DIR}/${ISO_PREFIX}.iso"
if [ -f "${ISO_FILE}" ]; then
    echo ">>> 注入 grubx64.efi 到 EFI 引导镜像（字节级）"
    # 从 Docker 镜像提取 grubx64.efi
    docker run --rm ${VDI_OS_IMAGE} cat /usr/share/efi/x86_64/grubx64.efi > /tmp/grubx64.efi
    chmod 700 /tmp/grubx64.efi

    # 定位 EFI 引导镜像偏移：扫描 ISO 找 FAT 引导扇区（0x55AA）+ 卷标 COS_GRUB
    EFI_OFF=$(python3 -c "
import sys
with open('${ISO_FILE}', 'rb') as f:
    data = f.read()
off = 0
while off < len(data) - 512:
    if data[off+0x1FE:off+0x200] == b'\x55\xAA':
        for voff in (0x2B, 0x47):
            label = data[off+voff:off+voff+11].rstrip(b'\x00 ')
            if b'COS_GRUB' in label:
                print(off); sys.exit(0)
    off += 2048
print(''); sys.exit(1)
")
    if [ -z "${EFI_OFF}" ]; then
        echo "  警告: 未在 ISO 中定位到 EFI 引导镜像，跳过 grubx64.efi 注入"
    else
        EFI_SIZE=8388608  # 8MB
        EFI_IMG="${CACHE_DIR}/efi-inject.img"
        echo "  EFI 镜像偏移: ${EFI_OFF}"
        # 提取 EFI 镜像
        dd if="${ISO_FILE}" of="${EFI_IMG}" bs=1 skip="${EFI_OFF}" count="${EFI_SIZE}" 2>/dev/null
        # 注入 grubx64.efi
        mcopy -i "${EFI_IMG}" /tmp/grubx64.efi "::EFI/BOOT/grubx64.efi"
        # 验证
        echo "  EFI 引导镜像内容:"
        mdir -i "${EFI_IMG}" ::EFI/BOOT/ 2>/dev/null
        if mdir -i "${EFI_IMG}" ::EFI/BOOT/ 2>/dev/null | grep -qi "grubx64"; then
            # 原位写回（conv=notrunc 不截断 ISO）
            dd if="${EFI_IMG}" of="${ISO_FILE}" bs=1024 seek=$((EFI_OFF/1024)) count=$((EFI_SIZE/1024)) conv=notrunc 2>/dev/null
            echo "  grubx64.efi 注入成功 ✓ (UEFI 引导就绪)"
        else
            echo "  警告: grubx64.efi 注入失败"
        fi
        rm -f "${EFI_IMG}"
    fi
    rm -f /tmp/grubx64.efi
fi


# ============================================================
# 步骤 8: 验证 ISO
# ============================================================
if [ ! -f "${ISO_FILE}" ]; then
    echo "ERROR: ISO 文件未生成: ${ISO_FILE}"
    exit 1
fi

echo ">>> ISO 内容验证"
echo "--- 卷标 ---"
isoinfo -d -i "${ISO_FILE}" 2>/dev/null | grep "Volume id" || true
echo "--- 关键文件 ---"
7z l "${ISO_FILE}" 2>/dev/null | grep -iE "rootfs.squashfs|loader/linux|loader/initrd|grub.cfg|kernel.xz" | head -10 || true

# 生成校验和
cd ${ARTIFACTS_DIR}
sha512sum ${ISO_PREFIX}.iso > ${ISO_PREFIX}.sha512

echo "============================================"
echo "  构建完成!"
echo "  ISO:   ${ISO_FILE}"
echo "  大小:  $(du -sh ${ISO_FILE} | cut -f1)"
echo "  SHA512:${ISO_PREFIX}.sha512"
echo "============================================"
