#!/bin/bash
set -e

TOP_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." &> /dev/null && pwd )"
SCRIPTS_DIR="${TOP_DIR}/scripts"
PACKAGE_VDI_OS_DIR="${TOP_DIR}/package/vdi-os"
PACKAGE_VDI_REPO_DIR="${TOP_DIR}/package/vdi-cluster-repo"
: ${RKE2_IMAGE_REPO:=https://github.com/rancher/rke2/releases/download/}

cd ${TOP_DIR}

source ${SCRIPTS_DIR}/version
source ${SCRIPTS_DIR}/version-rke2
source ${SCRIPTS_DIR}/version-kubevirt
source ${SCRIPTS_DIR}/version-longhorn
source ${SCRIPTS_DIR}/version-kubeovn
source ${SCRIPTS_DIR}/version-kagent
source ${SCRIPTS_DIR}/lib/http
source ${SCRIPTS_DIR}/lib/image

BUNDLE_DIR="${PACKAGE_VDI_OS_DIR}/iso/bundle"
CHARTS_DIR="${PACKAGE_VDI_REPO_DIR}/charts"
IMAGES_DIR="${BUNDLE_DIR}/vdi/images"
IMAGES_LISTS_DIR="${BUNDLE_DIR}/vdi/images-lists"
RANCHERD_IMAGES_DIR="${BUNDLE_DIR}/rancherd/images"
mkdir -p ${CHARTS_DIR}
mkdir -p ${IMAGES_DIR}
mkdir -p ${IMAGES_LISTS_DIR}
mkdir -p ${RANCHERD_IMAGES_DIR}

RKE2_VERSION_NORMALIZED=${RKE2_VERSION/+/-} # v1.21.3-rc6+rke2r2 -> v1.21.3-rc6-rke2r2

# ============================================================
# Rancherd bootstrap images（system-agent-installer-rke2，vdi-install 用 wharfie 从中提取 rke2 二进制+containerd）
# ============================================================
cat > /tmp/rancherd-bootstrap-images.txt <<EOF
docker.io/rancher/system-agent-installer-rke2:${RKE2_VERSION_NORMALIZED}
EOF
image_list_file="${RANCHERD_IMAGES_DIR}/rancherd-bootstrap-images-${RKE2_VERSION_NORMALIZED}.txt"
cp /tmp/rancherd-bootstrap-images.txt $image_list_file
save_image "agent" $BUNDLE_DIR $image_list_file ${RANCHERD_IMAGES_DIR}

# Use offline bundle cache
if [ -n "$VDI_INSTALLER_OFFLINE_BUILD" -a -e /bundle ]; then
  cp -rf /bundle/* ${BUNDLE_DIR}/
  exit 0
fi

# ============================================================
# RKE2 images
# ============================================================
RKE2_IMAGES_URL="${RKE2_IMAGE_REPO}${RKE2_VERSION}"
image_list_file="${IMAGES_LISTS_DIR}/rke2-images.linux-${ARCH}-${RKE2_VERSION_NORMALIZED}.txt"
image_archive="${IMAGES_DIR}/rke2-images.linux-${ARCH}-${RKE2_VERSION_NORMALIZED}.tar.zst"
get_url "${RKE2_IMAGES_URL}/rke2-images.linux-${ARCH}.txt" $image_list_file
get_url "${RKE2_IMAGES_URL}/rke2-images.linux-${ARCH}.tar.zst" $image_archive
add_image_list_to_metadata "rke2" $BUNDLE_DIR $image_list_file $image_archive

# RKE2 multus images (exclude SR-IOV)
image_list_file="${IMAGES_LISTS_DIR}/rke2-images-multus.linux-amd64-${RKE2_VERSION_NORMALIZED}.txt"
save_image_list "kubernetes" "${RKE2_IMAGES_URL}/rke2-images-multus.linux-amd64.txt" $image_list_file
save_image "rke2" $BUNDLE_DIR $image_list_file ${IMAGES_DIR}

# ============================================================
# RKE2 二进制（rke2 + containerd + chart-templates + systemd unit）
# kickstart %post 解压到 /usr/local，替代 elemental 链的 wharfie 提取
# ============================================================
BINARIES_DIR="${BUNDLE_DIR}/vdi/binaries"
mkdir -p ${BINARIES_DIR}
rke2_binary="${BINARIES_DIR}/rke2.linux-${ARCH}.tar.gz"
get_url "${RKE2_IMAGES_URL}/rke2.linux-${ARCH}.tar.gz" ${rke2_binary}
echo "==> RKE2 binary: $(ls -lh ${rke2_binary} 2>/dev/null | awk '{print $5}')"

# ============================================================
# Longhorn chart + images
# ============================================================
echo "==> Pulling Longhorn chart (v${LONGHORN_VERSION})"
if [ -f "${CHARTS_DIR}/longhorn-${LONGHORN_VERSION#v}.tgz" ]; then
    echo "Chart already exists: longhorn-${LONGHORN_VERSION#v}.tgz"
else
    helm repo add longhorn https://charts.longhorn.io 2>/dev/null || true
    helm pull longhorn/longhorn --version ${LONGHORN_VERSION#v} -d ${CHARTS_DIR}
fi

echo "==> Pulling Longhorn image list"
longhorn_image_list="${IMAGES_LISTS_DIR}/longhorn-images-${LONGHORN_VERSION}.txt"
get_url "https://raw.githubusercontent.com/longhorn/longhorn/${LONGHORN_VERSION}/deploy/longhorn-images.txt" ${longhorn_image_list}
# Remove unsupported image
sed -i '/longhornio\/openshift-origin-oauth-proxy/d' ${longhorn_image_list}
save_image "longhorn" $BUNDLE_DIR ${longhorn_image_list} ${IMAGES_DIR}

# ============================================================
# KubeVirt manifests + chart + images
# ============================================================
echo "==> Pulling KubeVirt operator chart (v${KUBEVIRT_VERSION})"
if [ -f "${CHARTS_DIR}/kubevirt-operator.yaml" ] || [ -f "${CHARTS_DIR}/kubevirt-operator-${KUBEVIRT_VERSION#v}.tgz" ]; then
    echo "Chart already exists: kubevirt-operator"
else
    helm repo add kubevirt https://kubevirt.io/latest/charts/ 2>/dev/null || true
    helm pull kubevirt/kubevirt-operator --version ${KUBEVIRT_VERSION#v} -d ${CHARTS_DIR} || \
      get_url "https://github.com/kubevirt/kubevirt/releases/download/${KUBEVIRT_VERSION}/kubevirt-operator.yaml" "${CHARTS_DIR}/kubevirt-operator.yaml"
fi

echo "==> Pulling KubeVirt image list"
kubevirt_image_list="${IMAGES_LISTS_DIR}/kubevirt-images-${KUBEVIRT_VERSION}.txt"
# Extract images from operator deployment manifest
curl -sfL "https://raw.githubusercontent.com/kubevirt/kubevirt/${KUBEVIRT_VERSION}/deploy/kubevirt-operator.yaml" | \
  grep -oP 'image:\s*\K.*' | sort -u > ${kubevirt_image_list} 2>/dev/null || true
# Also try the vmlauncher image list
curl -sfL "https://raw.githubusercontent.com/kubevirt/kubevirt/${KUBEVIRT_VERSION}/manifests/images/kubevirt-images.yaml" | \
  grep -E '^\s*-\s+"' | tr -d ' "' | sort -u >> ${kubevirt_image_list} 2>/dev/null || true
# Fallback: known core images
if [ ! -s ${kubevirt_image_list} ]; then
  cat > ${kubevirt_image_list} <<EOF
quay.io/kubevirt/virt-operator:${KUBEVIRT_VERSION}
quay.io/kubevirt/virt-controller:${KUBEVIRT_VERSION}
quay.io/kubevirt/virt-api:${KUBEVIRT_VERSION}
quay.io/kubevirt/virt-handler:${KUBEVIRT_VERSION}
quay.io/kubevirt/virt-launcher:${KUBEVIRT_VERSION}
quay.io/kubevirt/virt-exportproxy:${KUBEVIRT_VERSION}
quay.io/kubevirt/virt-exportserver:${KUBEVIRT_VERSION}
EOF
fi
save_image "kubevirt" $BUNDLE_DIR ${kubevirt_image_list} ${IMAGES_DIR}

# ============================================================
# Kube-OVN chart + images
# ============================================================
echo "==> Pulling Kube-OVN chart (v${KUBEOVN_VERSION})"
if [ -f "${CHARTS_DIR}/kube-ovn-${KUBEOVN_VERSION}.tgz" ]; then
    echo "Chart already exists: kube-ovn-${KUBEOVN_VERSION}.tgz"
else
    get_url "https://github.com/kubeovn/kube-ovn/releases/download/${KUBEOVN_VERSION}/kube-ovn-${KUBEOVN_VERSION}.tgz" \
      "${CHARTS_DIR}/kube-ovn-${KUBEOVN_VERSION}.tgz"
fi

echo "==> Pulling Kube-OVN image list"
kubeovn_image_list="${IMAGES_LISTS_DIR}/kubeovn-images-${KUBEOVN_VERSION}.txt"
curl -sfL "https://raw.githubusercontent.com/kubeovn/kube-ovn/${KUBEOVN_VERSION}/images/kube-ovn-amd64-${KUBEOVN_VERSION#v}.tar" 2>/dev/null | tar -tf - 2>/dev/null | sort -u > ${kubeovn_image_list} || true
# Fallback: known images
if [ ! -s ${kubeovn_image_list} ]; then
  cat > ${kubeovn_image_list} <<EOF
docker.io/kubeovn/kube-ovn:${KUBEOVN_VERSION}
EOF
fi
save_image "kubeovn" $BUNDLE_DIR ${kubeovn_image_list} ${IMAGES_DIR}

# ============================================================
# kagent chart + images
# ============================================================
echo "==> Pulling kagent chart (v${KAGENT_VERSION})"
if [ -f "${CHARTS_DIR}/kagent-${KAGENT_VERSION}.tgz" ]; then
    echo "Chart already exists: kagent-${KAGENT_VERSION}.tgz"
else
    get_url "https://github.com/kagent-dev/kagent/releases/download/v${KAGENT_VERSION}/kagent-${KAGENT_VERSION}.tgz" \
      "${CHARTS_DIR}/kagent-${KAGENT_VERSION}.tgz" || {
        echo "WARN: kagent chart 拉取失败，kagent 将无法部署（manifest 引用此 chart）" >&2
        echo "  如暂不需要 kagent，请从构建链与 manifest 中移除" >&2
    }
fi

# TODO(kagent): ghcr.io 需认证，kagent 镜像暂未打包，kagent 部署会因镜像缺失失败。
# 启用步骤：配置 GHCR 认证 → 取消下方注释 → 确认镜像可拉
# kagent_image_list="${IMAGES_LISTS_DIR}/kagent-images-${KAGENT_VERSION}.txt"
# cat > ${kagent_image_list} <<EOF
# ghcr.io/kagent-dev/kagent-controller:${KAGENT_VERSION}
# ghcr.io/kagent-dev/kagent-ui:${KAGENT_VERSION}
# ghcr.io/kagent-dev/kagent-proxy:${KAGENT_VERSION}
# ghcr.io/kagent-dev/kagent-tools:${KAGENT_VERSION}
# ghcr.io/kagent-dev/model-runner:${KAGENT_VERSION}
# docker.io/library/postgres:17.4-alpine
# EOF
# save_image "kagent" $BUNDLE_DIR ${kagent_image_list} ${IMAGES_DIR}
echo "Skipping kagent image pull (ghcr.io requires authentication, TODO)"


# ============================================================
# 把 Helm chart tgz 复制到 ISO bundle，供 vdi-install 复制到目标盘
# server/charts/（RKE2 HelmChart CRD spec.chart 引用这些路径）
# 重命名为 manifest 期望的名字（不带版本号），kubevirt 是 KubeVirt CR 不需 tgz
# ============================================================
CHARTS_BUNDLE_DIR="${BUNDLE_DIR}/vdi/charts"
mkdir -p ${CHARTS_BUNDLE_DIR}
echo "==> Copying Helm charts to bundle (renamed to manifest names)"
cp -f "${CHARTS_DIR}/kube-ovn-${KUBEOVN_VERSION}.tgz" "${CHARTS_BUNDLE_DIR}/kube-ovn.tgz"
cp -f "${CHARTS_DIR}/longhorn-${LONGHORN_VERSION#v}.tgz" "${CHARTS_BUNDLE_DIR}/longhorn.tgz"
# kagent chart 可能因 ghcr 认证未拉到，存在才复制
[ -f "${CHARTS_DIR}/kagent-${KAGENT_VERSION}.tgz" ] && \
  cp -f "${CHARTS_DIR}/kagent-${KAGENT_VERSION}.tgz" "${CHARTS_BUNDLE_DIR}/kagent.tgz" || \
  echo "WARN: kagent chart 缺失，不复制到 bundle"
ls -la ${CHARTS_BUNDLE_DIR}/

# ============================================================
# Create Helm repo index
# ============================================================
echo "==> Creating Helm repo index"
helm repo index ${CHARTS_DIR}

echo "==> Build bundle completed"
ls -la ${BUNDLE_DIR}/vdi/images/
