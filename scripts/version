#!/bin/bash

unset DIRTY
if [ -n "$(git status --porcelain --untracked-files=no)" ]; then
    DIRTY="-dirty"
fi

COMMIT=$(git rev-parse --short HEAD)

# CI 正式 tag 构建保留 tag（不因未提交改动丢失）；本地/branch 构建用 <commit>[-dirty]
if [ -n "${DRONE_TAG}" ]; then
    VERSION=${DRONE_TAG}
else
    VERSION="${COMMIT}${DIRTY:-}"
fi

if [ -z "$ARCH" ]; then
    ARCH=$(go env GOHOSTARCH)
fi
